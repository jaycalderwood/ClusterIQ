<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Brand / Accent ──────────────────────────────────────────────────── -->
    <Color x:Key="AccentColor">#3B9EF5</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

    <!-- ── Surfaces ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TitleBarBrush"       Color="#0D1117"/>
    <SolidColorBrush x:Key="WindowBgBrush"        Color="#0D1117"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="#161B22"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="#1C2128"/>
    <SolidColorBrush x:Key="ToolbarBrush"         Color="#161B22"/>

    <!-- ── Borders ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BorderBrush"          Color="#30363D"/>
    <SolidColorBrush x:Key="DividerBrush"         Color="#21262D"/>

    <!-- ── Text ─────────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ForegroundBrush"      Color="#E6EDF3"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#8B949E"/>
    <SolidColorBrush x:Key="TabActiveFgBrush"     Color="#3B9EF5"/>
    <SolidColorBrush x:Key="TabInactiveFgBrush"   Color="#8B949E"/>

    <!-- ── DataGrid ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridRowBrush"         Color="#161B22"/>
    <SolidColorBrush x:Key="GridAltRowBrush"      Color="#1C2128"/>
    <SolidColorBrush x:Key="GridHeaderBgBrush"    Color="#1C2128"/>
    <SolidColorBrush x:Key="GridHeaderFgBrush"    Color="#C9D1D9"/>
    <SolidColorBrush x:Key="GridLineBrush"        Color="#21262D"/>

    <!-- ── Metric Cards ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="MetricCardBgBrush"    Color="#1C2128"/>

    <!-- ── Input fields ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InputBgBrush"         Color="#0D1117"/>
    <SolidColorBrush x:Key="InputBorderBrush"     Color="#30363D"/>

    <!-- ── Cluster sidebar ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SidebarBgBrush"       Color="#1C2128"/>
    <SolidColorBrush x:Key="SidebarItemActiveBg"  Color="#1D3A5F"/>
    <SolidColorBrush x:Key="SidebarItemHoverBg"   Color="#21262D"/>

</ResourceDictionary>
