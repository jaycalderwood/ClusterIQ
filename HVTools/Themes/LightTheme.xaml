<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Brand / Accent ──────────────────────────────────────────────────── -->
    <Color x:Key="AccentColor">#0078D4</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

    <!-- ── Surfaces ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TitleBarBrush"       Color="#003A6E"/>
    <SolidColorBrush x:Key="WindowBgBrush"        Color="#F5F6FA"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="#F9FAFB"/>
    <SolidColorBrush x:Key="ToolbarBrush"         Color="#FFFFFF"/>

    <!-- ── Borders ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BorderBrush"          Color="#E1E4E8"/>
    <SolidColorBrush x:Key="DividerBrush"         Color="#EDEFF2"/>

    <!-- ── Text ─────────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ForegroundBrush"      Color="#111827"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TabActiveFgBrush"     Color="#0078D4"/>
    <SolidColorBrush x:Key="TabInactiveFgBrush"   Color="#6B7280"/>

    <!-- ── DataGrid ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridRowBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="GridAltRowBrush"      Color="#FAFBFC"/>
    <SolidColorBrush x:Key="GridHeaderBgBrush"    Color="#F3F4F6"/>
    <SolidColorBrush x:Key="GridHeaderFgBrush"    Color="#374151"/>
    <SolidColorBrush x:Key="GridLineBrush"        Color="#EDEFF2"/>

    <!-- ── Metric Cards ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="MetricCardBgBrush"    Color="#FFFFFF"/>

    <!-- ── Input fields ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InputBgBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush"     Color="#D1D5DB"/>

    <!-- ── Cluster sidebar ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SidebarBgBrush"       Color="#F0F2F5"/>
    <SolidColorBrush x:Key="SidebarItemActiveBg"  Color="#DBEAFE"/>
    <SolidColorBrush x:Key="SidebarItemHoverBg"   Color="#E5E7EB"/>

</ResourceDictionary>
