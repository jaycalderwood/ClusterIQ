<Window x:Class="HVTools.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ClusterIQ"
        Width="620"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBgBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="ClusterIQ" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBlock Text="{Binding VersionText}" Margin="0,6,0,0" FontSize="13" Foreground="{DynamicResource MutedForegroundBrush}"/>
            <TextBlock Text="Repository: https://github.com/jaycalderwood/ClusterIQ"
                       Margin="0,4,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource AccentBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Update Status" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="{Binding UpdateStatusText}" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="{Binding ReleaseMetaText}" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedForegroundBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Release Notes" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBox Text="{Binding ReleaseNotesText}"
                                 Margin="0,10,0,0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="240"
                                 Background="{DynamicResource InputBgBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource InputBorderBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Check for Updates" Width="150" Margin="0,0,8,0" Click="CheckForUpdates_Click"/>
            <Button Content="Update Now" Width="120" Margin="0,0,8,0" Click="UpdateNow_Click"/>
            <Button Content="Close" Width="100" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
