<Window x:Class="HVTools.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClusterIQ Documentation"
        Height="760"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#FFF7F7F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#FF0F172A" CornerRadius="10" Padding="18" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ClusterIQ Documentation"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock Text="Hyper-V, Azure Local, Storage Spaces Direct, and Azure Arc Intelligence Platform"
                           Foreground="#FFE2E8F0"
                           FontSize="13"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="4">

                <Border Background="White" CornerRadius="8" BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Overview" FontSize="20" FontWeight="Bold" Foreground="#FF111827"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#FF374151"
                                   Text="ClusterIQ is a practical management console for Hyper-V clusters and Azure Local environments. It is designed for operators who need fast visibility into hosts, clusters, virtual machines, storage, and update posture while still being able to perform common VM actions from the same interface."/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="What ClusterIQ Covers" FontSize="20" FontWeight="Bold" Foreground="#FF111827"/>
                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="Virtual Machines"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="Inventory, state, host placement, CPU and memory assignment, start, stop, restart, and live migration."/>
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="Infrastructure"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="Hyper-V host inventory, cluster totals, switches, NICs, storage views, and Azure Stack HCI / S2D status."/>
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="Export"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="Current-tab export to CSV or XLSX for quick operational reporting."/>
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="Updates"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="Startup update checks and an About window workflow that can review and apply GitHub release updates."/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Live Migration" FontSize="20" FontWeight="Bold" Foreground="#FF111827"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#FF374151"
                                   Text="Select a VM from the VM inventory tab, choose the destination host from the dropdown, and run the move. ClusterIQ submits the migration, refreshes inventory, and re-evaluates the selected VM against the target host."/>
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="Authentication Modes"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="ClusterIQ supports Kerberos and CredSSP as configurable live migration authentication preferences. All participating hosts should use the same Hyper-V live migration authentication type. Kerberos is generally the preferred choice for clustered live migration when the environment is configured to support it."/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Performance View" FontSize="20" FontWeight="Bold" Foreground="#FF111827"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#FF374151"
                                   Text="The HV Perf tab summarizes collected performance metrics and renders a time-series sparkline for the selected row. Use the refresh interval selector to control automatic refresh or turn it off when you want a static view."/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Operational Notes" FontSize="20" FontWeight="Bold" Foreground="#FF111827"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#FF374151"
                                   Text="ClusterIQ collects live data through PowerShell. Some tabs depend on the modules and cmdlets available on the queried node, and some cluster or storage state can lag briefly behind what Hyper-V or Windows Admin Center shows immediately after an action."/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Troubleshooting" FontSize="20" FontWeight="Bold" Foreground="#FF111827"/>
                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="Migration succeeded but the VM still shows the old host"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="Wait briefly and use Refresh if needed. The environment can settle after a move before every view reflects the new placement."/>
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="S2D returned a diagnostic row"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="That usually means the queried node did not return a usable non-primordial pool or returned a diagnostic message instead of pool data."/>
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#FF111827" Text="Disk or storage details appear incomplete"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FF374151"
                                   Text="Verify permissions, module availability, and storage cmdlet behavior on the queried node."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#FFD1D5DB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,0">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Created by" FontWeight="Bold" Foreground="#FF111827"/>
                    <TextBlock Text="Jay Calderwood" Foreground="#FF374151"/>
                    <TextBlock Text="jayc@ccstechnj.com" Foreground="#FF374151"/>
                    <TextBlock Text="https://www.cloudythoughts.cloud" Foreground="#FF374151"/>
                    <TextBlock Text="Repository: https://github.com/jaycalderwood/ClusterIQ" Foreground="#FF374151"/>
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Width="100"
                        Height="34"
                        Margin="12,0,0,0"
                        Content="Close"
                        Click="CloseButton_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
