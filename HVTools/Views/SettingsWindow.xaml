<Window x:Class="HVTools.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClusterIQ Settings"
        Height="520"
        Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBgBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="General Settings" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        <CheckBox Content="Enable notifications"
                                  IsChecked="{Binding EnableNotifications}"
                                  Margin="0,12,0,0"
                                  Foreground="{DynamicResource ForegroundBrush}"/>
                        <CheckBox Content="Enable update checks"
                                  IsChecked="{Binding CheckForUpdates}"
                                  Margin="0,8,0,0"
                                  Foreground="{DynamicResource ForegroundBrush}"/>
                        <CheckBox Content="Save connection information"
                                  IsChecked="{Binding SaveConnectionInfo}"
                                  Margin="0,8,0,0"
                                  Foreground="{DynamicResource ForegroundBrush}"/>
                        <CheckBox Content="Use dark mode"
                                  IsChecked="{Binding IsDarkMode}"
                                  Margin="0,8,0,0"
                                  Foreground="{DynamicResource ForegroundBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Thresholds" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="CPU warning (%):" Width="190" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBox Width="100" Text="{Binding CpuWarnThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Memory warning (%):" Width="190" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBox Width="100" Text="{Binding MemoryWarnThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Storage warning (%):" Width="190" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBox Width="100" Text="{Binding StorageWarnThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Snapshot retention:" Width="190" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBox Width="100" Text="{Binding SnapshotRetentionCount, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Live Migration Settings" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="Preferred auth mode:" Width="190" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                            <ComboBox Width="180" SelectedValue="{Binding LiveMigrationAuthMode, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content">
                                <ComboBoxItem Content="Kerberos"/>
                                <ComboBoxItem Content="CredSSP"/>
                            </ComboBox>
                        </StackPanel>
                        <CheckBox Content="Apply selected auth mode to connected hosts when connecting"
                                  IsChecked="{Binding ApplyLiveMigrationAuthOnConnect}"
                                  Margin="0,12,0,0"
                                  Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="Kerberos is recommended for cluster live migration. CredSSP may be useful for direct-host administrative scenarios. Applying the mode changes Hyper-V host migration authentication on connected nodes."
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Save" Width="100" Margin="0,0,8,0" Click="Save_Click"/>
                    <Button Content="Cancel" Width="100" Click="Cancel_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Height="30" Margin="0,0,8,0" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
